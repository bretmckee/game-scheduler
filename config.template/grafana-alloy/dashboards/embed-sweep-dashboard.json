{
  "title": "Embed Deletion Sweep",
  "description": "Performance monitoring for the bot embed deletion sweep: how often sweeps run, how much work they do, and whether they are interrupted by reconnects",
  "tags": ["bot", "sweep", "gateway", "otel"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 0,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus Datasource",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Sweeps Started (last 1h)",
      "description": "Total embed deletion sweep cycles triggered in the last hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(bot_sweep_started_total[1h]))",
          "legendFormat": "Sweeps",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "Sweeps Interrupted (last 1h)",
      "description": "Number of sweeps cancelled because a new sweep was triggered before the previous one finished — non-zero values indicate rapid bot reconnects",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(bot_sweep_interrupted_total[1h]))",
          "legendFormat": "Interrupted",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "title": "Messages Checked (last 1h)",
      "description": "Total Discord messages fetched to verify they still exist — proportional to the number of active games with embed posts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(bot_sweep_messages_checked_total[1h]))",
          "legendFormat": "Checked",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Deletions Detected (last 1h)",
      "description": "Total EMBED_DELETED events published — each represents a game embed that was deleted while the bot was offline",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(bot_sweep_deletions_detected_total[1h]))",
          "legendFormat": "Deleted",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "title": "Sweep Starts by Reason",
      "description": "Rate of sweep cycles triggered over time — on_ready fires at bot startup, on_resumed fires after a Gateway reconnect",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(bot_sweep_started_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineInterpolation": "linear", "spanNulls": false }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Messages Checked and Deletions Detected",
      "description": "Rate of Discord messages fetched (messages_checked) vs embed deletions found (deletions_detected) — deletions should be rare under normal operation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(bot_sweep_messages_checked_total[5m])",
          "legendFormat": "Messages Checked",
          "refId": "A"
        },
        {
          "expr": "rate(bot_sweep_deletions_detected_total[5m])",
          "legendFormat": "Deletions Detected",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineInterpolation": "linear", "spanNulls": false }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Sweep Duration by Reason",
      "description": "p50 and p99 wall-clock time to complete a full sweep, per trigger reason — startup sweeps (on_ready) check all active games; reconnect sweeps (on_resumed) do the same",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, reason) (rate(bot_sweep_duration_bucket[5m])))",
          "legendFormat": "p99 {{reason}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, reason) (rate(bot_sweep_duration_bucket[5m])))",
          "legendFormat": "p50 {{reason}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineInterpolation": "linear", "spanNulls": false }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "title": "Sweep Interruptions Over Time",
      "description": "Rate of sweep cancellations caused by a new sweep being triggered — persistent non-zero values indicate the bot is reconnecting repeatedly",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(bot_sweep_interrupted_total[5m]))",
          "legendFormat": "interrupted by {{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineInterpolation": "linear", "spanNulls": false }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
