{
  "title": "Gateway Projection",
  "description": "Performance monitoring for the bot gateway member projection: repopulation frequency, duration, and member scale",
  "tags": ["bot", "projection", "gateway", "otel"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 0,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Prometheus Datasource",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Repopulations (last 1h)",
      "description": "Total projection repopulation cycles across all trigger reasons in the last hour",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(bot_projection_repopulation_started_total[1h]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "Repopulation Duration p50 (current)",
      "description": "Median repopulation wall-clock time over the last 5 minutes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(bot_projection_repopulation_duration_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 3,
      "title": "Repopulation Rate by Reason",
      "description": "How often projection repopulations are triggered, broken down by the gateway event that caused them (on_ready, member_add, member_update, member_remove)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (reason) (rate(bot_projection_repopulation_started_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "lineInterpolation": "linear", "spanNulls": false }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "Repopulation Duration by Reason",
      "description": "p50 and p99 wall-clock time for each repopulation cycle, per trigger reason — high p99 indicates the Redis write is slow or the guild has many members",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, reason) (rate(bot_projection_repopulation_duration_bucket[5m])))",
          "legendFormat": "p99 {{reason}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, reason) (rate(bot_projection_repopulation_duration_bucket[5m])))",
          "legendFormat": "p50 {{reason}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineInterpolation": "linear", "spanNulls": false }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Members Written per Repopulation",
      "description": "p50 and p99 member count written per repopulation cycle — reflects guild size; a spike indicates a large guild was added or all members were re-fetched",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, reason) (rate(bot_projection_repopulation_members_written_bucket[5m])))",
          "legendFormat": "p99 {{reason}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, reason) (rate(bot_projection_repopulation_members_written_bucket[5m])))",
          "legendFormat": "p50 {{reason}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineInterpolation": "linear", "spanNulls": false }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
